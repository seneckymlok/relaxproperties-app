{
  "crons": [
    {
      "path": "/api/admin/sync/czech",
      "schedule": "0 0 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*).(js|css|woff2|woff|ttf|otf|ico|svg|png|jpg|jpeg|webp|avif|gif)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
